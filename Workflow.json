        "jsCode": "// 1. Obtener el texto crudo de Gemini\nconst rawText = $input.first().json.output;\n\n// 2. Limpiar los caracteres de markdown (```json y ```)\nconst cleanText = rawText.replace(/```json\\n?/g, '').replace(/```/g, '').trim();\n\n// 3. Convertir el texto a un objeto JSON real\nconst parsedJson = JSON.parse(cleanText);\n\n// 4. Retornar el JSON limpio\nreturn { json: parsedJson };"
